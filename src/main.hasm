#include "lib/hiolib.hasm"
#include "lib/string.hasm"

#include "kernel.hasm"
#include "shell.hasm"
#include "loader.hasm"

.entry _start

_start:
    call initKern

    ; OS
    push welcome
    call putstr

    osloop:
        call shell

        jmp osLoop

    ; --

    exit

.data
    welcome: db "Welcome to SYSDOS!\n"