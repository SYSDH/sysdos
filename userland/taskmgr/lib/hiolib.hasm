putstr:
    store 840008, li
    store 840012, he
    store 840016, c

    pop c
    pop li
    
    __putstrloop__:
        load $li, $he
        jz he, __putstrend__
        
        out $he, 1
        add li, 4
        jmp __putstrloop__

    __putstrend__:
        push $c

        load 840008, li
        load 840012, he
        load 840016, c
ret